{
  "name": "lula-ai-agent",
  "displayName": "Lula — AI Coding Agent",
  "description": "Submit coding tasks to the Lula autonomous coding agent. Sandboxed execution, structured verification, real-time streaming.",
  "version": "0.1.0",
  "publisher": "christianmeurer",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/christianmeurer/Lula.git"
  },
  "homepage": "https://github.com/christianmeurer/Lula#readme",
  "bugs": {
    "url": "https://github.com/christianmeurer/Lula/issues"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "AI",
    "Machine Learning",
    "Other"
  ],
  "keywords": [
    "ai",
    "coding-agent",
    "autonomous",
    "sandbox",
    "code-repair"
  ],
  "activationEvents": [
    "onView:orchestrator.runTree"
  ],
  "main": "./out/extension.js",
  "icon": "resources/icon.png",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "lula-sidebar",
          "title": "Lula",
          "icon": "resources/icon.svg"
        }
      ]
    },
    "views": {
      "lula-sidebar": [
        {
          "id": "orchestratorRuns",
          "name": "Orchestrator Runs"
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "orchestrator.refreshRuns",
          "when": "view == orchestratorRuns",
          "group": "navigation"
        },
        {
          "command": "orchestrator.newRun",
          "when": "view == orchestratorRuns",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "orchestrator.openRun",
          "when": "view == orchestratorRuns"
        }
      ]
    },
    "commands": [
      {
        "command": "lula.runTask",
        "title": "Lula: Run Task"
      },
      {
        "command": "lula.showRuns",
        "title": "Lula: Show Recent Runs"
      },
      {
        "command": "lula.approveRun",
        "title": "Lula: Approve Run"
      },
      {
        "command": "lula.rejectRun",
        "title": "Lula: Reject Run"
      },
      {
        "command": "lula.cancelRun",
        "title": "Lula: Cancel Run"
      },
      {
        "command": "lula.openRunPanel",
        "title": "Lula: Open Run Panel"
      },
      {
        "command": "lula.configure",
        "title": "Lula: Configure"
      },
      {
        "command": "orchestrator.refreshRuns",
        "title": "Refresh Runs",
        "icon": "$(refresh)"
      },
      {
        "command": "orchestrator.openRun",
        "title": "Open Run Panel"
      },
      {
        "command": "orchestrator.newRun",
        "title": "New Orchestrator Run",
        "icon": "$(add)"
      }
    ],
    "configuration": {
      "title": "Lula",
      "properties": {
        "lula.serverUrl": {
          "type": "string",
          "default": "https://lula.eiv.eng.br",
          "description": "Lula server URL"
        }
      }
    },
    "keybindings": [
      {
        "command": "lula.runTask",
        "key": "ctrl+shift+l",
        "mac": "cmd+shift+l"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "node esbuild.js --production",
    "compile": "node esbuild.js",
    "watch": "node esbuild.js --watch",
    "package": "vsce package",
    "publish": "vsce publish"
  },
  "devDependencies": {
    "@vscode/vsce": "^3.0.0",
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "typescript": "^5.0.0"
  }
}
