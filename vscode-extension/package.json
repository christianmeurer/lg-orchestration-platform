{
  "name": "lg-orchestration",
  "displayName": "Lula",
  "description": "VS Code extension for Lula.",
  "version": "0.1.0",
  "publisher": "lg-orchestration",
  "repository": {
    "type": "git",
    "url": "https://github.com/christianmeurer/Lula.git"
  },
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onCommand:lgOrch.openPanel",
    "onCommand:lgOrch.runRequest",
    "onCommand:lgOrch.startRunner",
    "onCommand:lgOrch.stopRunner",
    "onCommand:lgOrch.openRunHistory",
    "onCommand:lgOrch.clearRunHistory",
    "onChatParticipant:lula",
    "onView:orchestratorRuns",
    "onCommand:orchestrator.refreshRuns",
    "onCommand:orchestrator.openRun",
    "onCommand:orchestrator.newRun"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "lula-sidebar",
          "title": "Lula",
          "icon": "resources/icon.svg"
        }
      ]
    },
    "views": {
      "lula-sidebar": [
        {
          "id": "orchestratorRuns",
          "name": "Orchestrator Runs"
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "orchestrator.refreshRuns",
          "when": "view == orchestratorRuns",
          "group": "navigation"
        },
        {
          "command": "orchestrator.newRun",
          "when": "view == orchestratorRuns",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "orchestrator.openRun",
          "when": "view == orchestratorRuns"
        }
      ]
    },
    "chatParticipants": [
      {
        "id": "lula",
        "name": "lula",
        "description": "Talk to the Lula Orchestration Platform",
        "isDefault": true,
        "commands": [
          {
            "name": "run",
            "description": "Execute an agentic coding task"
          }
        ]
      }
    ],
    "commands": [
      {
        "command": "lgOrch.openPanel",
        "title": "Lula: Open Panel"
      },
      {
        "command": "lgOrch.runRequest",
        "title": "Lula: Run Request"
      },
      {
        "command": "lgOrch.startRunner",
        "title": "Lula: Start Runner"
      },
      {
        "command": "lgOrch.stopRunner",
        "title": "Lula: Stop Runner"
      },
      {
        "command": "lgOrch.openRunHistory",
        "title": "Lula: Open Run History"
      },
      {
        "command": "lgOrch.clearRunHistory",
        "title": "Lula: Clear Run History"
      },
      {
        "command": "lgOrch.viewInlineDiff",
        "title": "Lula: View Inline Diff"
      },
      {
        "command": "orchestrator.refreshRuns",
        "title": "Refresh Runs",
        "icon": "$(refresh)"
      },
      {
        "command": "orchestrator.openRun",
        "title": "Open Run Panel"
      },
      {
        "command": "orchestrator.newRun",
        "title": "New Orchestrator Run",
        "icon": "$(add)"
      }
    ],
    "configuration": {
      "title": "Lula",
      "properties": {
        "lula.remoteApiBaseUrl": {
          "type": "string",
          "default": "",
          "description": "Base URL for the hosted Lula remote API. When set, Run Request uses the remote API instead of local uv/cargo execution."
        },
        "lula.remoteApiBearerToken": {
          "type": "string",
          "default": "",
          "description": "Bearer token for the hosted Lula remote API when remote API auth is enabled. Prefer user settings over workspace settings."
        },
        "lula.remotePollIntervalMs": {
          "type": "number",
          "default": 1000,
          "minimum": 250,
          "description": "Polling interval in milliseconds for remote run status and logs."
        },
        "lula.runnerBindAddress": {
          "type": "string",
          "default": "127.0.0.1:8088",
          "description": "Bind address for the local Rust runner process (host:port)."
        },
        "lula.runnerApiKey": {
          "type": "string",
          "default": "dev-insecure",
          "description": "API key for the local Rust runner. Prefer user settings over workspace settings."
        },
        "lula.runnerBinaryPath": {
          "type": "string",
          "default": "",
          "description": "Path to a pre-built lg-runner binary. When empty, the extension builds via cargo run."
        },
        "lula.showInlineDiff": {
          "type": "boolean",
          "default": true,
          "description": "Show inline diff of file changes from apply_patch tool results in the panel."
        },
        "lula.maxRunHistory": {
          "type": "number",
          "default": 20,
          "minimum": 1,
          "maximum": 200,
          "description": "Maximum number of past runs to show in the run history section."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "node esbuild.js --production",
    "compile": "node esbuild.js",
    "watch": "node esbuild.js --watch",
    "package": "vsce package",
    "publish": "vsce publish"
  },
  "devDependencies": {
    "@vscode/vsce": "^3.0.0",
    "@types/node": "^20.14.10",
    "@types/vscode": "^1.90.0",
    "esbuild": "^0.20.0",
    "typescript": "^5.5.4"
  }
}
