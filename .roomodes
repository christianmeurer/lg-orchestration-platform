                                               {
                                                   "fileRegex":  "\\.(md|txt)$",
                                                   "description":  "Docs only"
                                               }
                                           ]
                                       ]
                        },
                        {
                            "slug":  "debug",
                            "name":  "Debug",
                            "roleDefinition":  "Find root cause, then patch minimally.",
                            "customInstructions":  "Reproduce, isolate, fix, verify. Keep logs and edits minimal.",
                            "groups":  [
                                           "read",
                                           [
                                               "edit",
                                               {
                                                   "fileRegex":  "\\.(py|rs|ts|toml|json|ya?ml|md|txt|log)$",
                                                   "description":  "Source, config, logs"
                                               }
                                           ],
                                           "command"
                                       ]
                        },
                        {
                            "slug":  "orchestrator",
