                                               }
                                           ],
                                           "command"
                                       ]
                        },
                        {
                            "slug":  "ask",
                            "name":  "Ask",
                            "roleDefinition":  "Explain briefly and precisely.",
                            "customInstructions":  "Default to terse direct answers. Read only what is needed.",
                            "groups":  [
                                           "read"
                                       ]
                        },
                        {
                            "slug":  "architect",
