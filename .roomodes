{
    "customModes":  [
                        {
                            "slug":  "code",
                            "name":  "Code",
                            "roleDefinition":  "Implement safely with minimal output.",
                            "customInstructions":  "Read only needed files. Use the smallest correct diff. No chatter.",
                            "groups":  [
                                           "read",
                                           [
